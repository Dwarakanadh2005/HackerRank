import string

def print_rangoli(size):
    # Get all lowercase letters
    alpha = string.ascii_lowercase
    
    lines = []
    for i in range(size):
        # Slice the characters needed for the current row
        # From character at index 'size-1' down to 'i'
        s = "-".join(alpha[size-1:i:-1] + alpha[i:size])
        
        # Center the string within the full width of the rangoli
        # The width formula is (size * 4) - 3
        lines.append(s.center(4 * size - 3, "-"))
    
    # Print the top half + middle + bottom half (reversed top half)
    # lines[::-1] provides the top half, lines[0] is the middle, etc.
    print('\n'.join(lines[::-1] + lines[1:]))


    END AS node_type
FROM BST
ORDER BY N;

23)https://www.hackerrank.com/challenges/the-company/problem?isFullScreen=true
--------
SELECT 
    c.company_code,
    c.founder,
    COALESCE(lm.lead_count, 0) AS total_lead_managers,
    COALESCE(sm.senior_count, 0) AS total_senior_managers,
    COALESCE(mgr.manager_count, 0) AS total_managers,
    COALESCE(emp.employee_count, 0) AS total_employees
FROM Company c
LEFT JOIN (
    SELECT company_code, COUNT(DISTINCT lead_manager_code) AS lead_count
    FROM Lead_Manager
    GROUP BY company_code
) lm ON c.company_code = lm.company_code
LEFT JOIN (
    SELECT company_code, COUNT(DISTINCT senior_manager_code) AS senior_count
    FROM Senior_Manager
    GROUP BY company_code
) sm ON c.company_code = sm.company_code
LEFT JOIN (
    SELECT company_code, COUNT(DISTINCT manager_code) AS manager_count
    FROM Manager
    GROUP BY company_code
) mgr ON c.company_code = mgr.company_code
LEFT JOIN (
    SELECT company_code, COUNT(DISTINCT employee_code) AS employee_count
    FROM Employee
    GROUP BY company_code
) emp ON c.company_code = emp.company_code
ORDER BY c.company_code ASC;

